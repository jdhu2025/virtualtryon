# ============================================================
# AI穿搭助手 - 本地环境变量示例
# ============================================================
#
# 使用方式：
# 1. 复制本文件为 .env.local
# 2. 填写真实值
# 3. 修改后重启 `pnpm dev`
#
# 当前推荐方案：
# - 关系数据：Supabase
# - 图片存储：Cloudflare R2
#
# ============================================================

# ------------------------------------------------------------
# 一、Supabase（关系数据，必填）
# ------------------------------------------------------------

# Supabase 项目地址
COZE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key
COZE_SUPABASE_ANON_KEY=your-anon-key

# 服务端写库建议填写 service role key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 站点地址（分享链接等场景会用到）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ------------------------------------------------------------
# 二、Cloudflare R2（图片存储，必填）
# ------------------------------------------------------------

# Cloudflare 账户 ID
CLOUDFLARE_ACCOUNT_ID=your-account-id

# R2 S3 凭证：Access Key ID
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 S3 凭证：Secret Access Key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 bucket 名称
CLOUDFLARE_R2_BUCKET=virtual-tryon

# R2 公共访问域名
# 可以是默认的 r2.dev 子域名，也可以是自定义域名
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ------------------------------------------------------------
# 三、AI 配置（按需）
# ------------------------------------------------------------
#
# 衣服分析、穿搭生成等 AI 能力依赖你当前使用的模型服务。
# 如果是在 Coze / 集成平台下运行，这部分通常由平台注入。
# 本项目本地只列出常见需要的变量名，具体值以你的模型服务为准。
#
# COZE_WORKLOAD_IDENTITY_API_KEY=your-api-key
# COZE_INTEGRATION_BASE_URL=https://your-integration-base-url
# COZE_INTEGRATION_MODEL_BASE_URL=https://your-model-base-url

# ------------------------------------------------------------
# 四、本地开发说明
# ------------------------------------------------------------
#
# 1. 初始化数据库：
#    在 Supabase SQL Editor 执行 `supabase/init.sql`
#
# 2. 启动开发服务：
#    pnpm dev
#
# 3. 本地默认访问地址：
#    http://localhost:3000
#
# 4. 如果刚修改过 .env.local：
#    需要重启 `pnpm dev` 才会生效
#
# ============================================================
