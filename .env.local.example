# ============================================================
# AI穿搭助手 - 本地环境变量示例
# ============================================================
#
# 使用方式：
# 1. 复制本文件为 .env.local
# 2. 填写真实值
# 3. 修改后重启 `pnpm dev`
#
# 当前推荐方案：
# - 关系数据：Supabase
# - 图片存储：Cloudflare R2
#
# ============================================================

# ------------------------------------------------------------
# 一、Supabase（关系数据，必填）
# ------------------------------------------------------------

# Supabase 项目地址
COZE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon key
COZE_SUPABASE_ANON_KEY=your-anon-key

# 服务端写库建议填写 service role key
COZE_SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# 站点地址（分享链接等场景会用到）
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Cloudflare Turnstile（人机验证）
# Site key 可公开给前端组件使用
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key
# Secret key 只能放后端环境变量，绝不能暴露到前端
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ------------------------------------------------------------
# 二、Cloudflare R2（图片存储，必填）
# ------------------------------------------------------------

# Cloudflare 账户 ID
CLOUDFLARE_ACCOUNT_ID=your-account-id

# R2 S3 凭证：Access Key ID
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id

# R2 S3 凭证：Secret Access Key
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key

# R2 bucket 名称
CLOUDFLARE_R2_BUCKET=virtual-tryon

# R2 公共访问域名
# 可以是默认的 r2.dev 子域名，也可以是自定义域名
CLOUDFLARE_R2_PUBLIC_URL=https://pub-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx.r2.dev

# ------------------------------------------------------------
# 三、AI 配置（按需）
# ------------------------------------------------------------
#
# 衣服分析、穿搭生成等 AI 能力依赖你当前使用的模型服务。
# 如果是在 Coze / 集成平台下运行，这部分通常由平台注入。
# 本项目本地只列出常见需要的变量名，具体值以你的模型服务为准。
#
# COZE_WORKLOAD_IDENTITY_API_KEY=your-api-key
# COZE_INTEGRATION_BASE_URL=https://your-integration-base-url
# COZE_INTEGRATION_MODEL_BASE_URL=https://your-model-base-url

# ------------------------------------------------------------
# 四、AI 分层路由（推荐）
# ------------------------------------------------------------
#
# 本项目把 AI 分成三层：
# 1. 文本/识图层：聊天文案、衣服识别、人物识别、上传分拣
# 2. 通用生图层：普通搭配图、概念图、测试生图
# 3. 垂直试衣层：虚拟试衣、换装、专业 try-on
#
# 当前推荐顺序（偏真实改图、服饰替换）：
# - 文本/识图：ModelScope -> 火山
# - 通用生图：百炼 -> 火山 -> ModelScope -> Coze
# - 垂直试衣：
#   free  = 百炼同步图编辑 -> 火山
#   paid  = FASHN -> 百炼 -> 火山

# 4.1 文本 / 识图层
AI_TEXT_VISION_TIER=free
AI_TEXT_VISION_PROVIDERS_FREE=modelscope,volcengine
AI_TEXT_VISION_PROVIDERS_PAID=modelscope,volcengine

# ModelScope（文本 / 识图 / 通用生图）
# MODELSCOPE_API_KEY=your-modelscope-sdk-token
# 或 MODELSCOPE_SDK_TOKEN=your-modelscope-sdk-token
# MODELSCOPE_BASE_URL=https://api-inference.modelscope.cn/v1
# MODELSCOPE_TEXT_VISION_TEXT_MODEL=Qwen/Qwen2.5-7B-Instruct
# MODELSCOPE_TEXT_VISION_VISION_MODEL=Qwen/Qwen2.5-VL-72B-Instruct

# 百炼（文本 / 识图）
# BAILIAN_API_KEY=your-bailian-api-key
# 或 DASHSCOPE_API_KEY=your-dashscope-api-key
# BAILIAN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# BAILIAN_TEXT_VISION_TEXT_MODEL=qwen-flash
# BAILIAN_TEXT_VISION_VISION_MODEL=qwen3-vl-flash

# 火山引擎（文本 / 识图 / 通用生图）
# VOLCENGINE_API_KEY=your-volcengine-api-key
# 或 ARK_API_KEY=your-ark-api-key
# VOLCENGINE_MODEL_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VOLCENGINE_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
# VOLCENGINE_TEXT_VISION_TEXT_MODEL=doubao-seed-1-6-251015
# VOLCENGINE_TEXT_VISION_VISION_MODEL=doubao-seed-1-6-vision-250815

# Gemini（文本 / 识图 / 通用生图）
# GEMINI_API_KEY=your-gemini-api-key
# 或 GOOGLE_API_KEY=your-google-api-key
# GEMINI_TEXT_VISION_TEXT_MODEL=gemini-2.5-flash
# GEMINI_TEXT_VISION_VISION_MODEL=gemini-2.5-flash

# 4.2 通用生图层
AI_GENERAL_IMAGE_TIER=free
AI_GENERAL_IMAGE_PROVIDERS_FREE=bailian,volcengine,modelscope,coze
AI_GENERAL_IMAGE_PROVIDERS_PAID=bailian,volcengine,modelscope,coze

# 百炼通用图像编辑 / 生图
# BAILIAN_IMAGE_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/multimodal-generation/generation
# BAILIAN_GENERAL_IMAGE_MODEL=qwen-image-2.0
# BAILIAN_GENERAL_IMAGE_SIZE=1024*1536

# ModelScope 通用生图
# MODELSCOPE_GENERAL_IMAGE_MODEL=MAILAND/majicflus_v1

# 火山通用生图（默认显式使用 Seedream 5.0）
# 如果你的账号里开通的是别的 Seedream 版本，可以直接覆盖这个模型名。
# VOLCENGINE_GENERAL_IMAGE_MODEL=doubao-seedream-5-0-260128

# Gemini 通用生图
# GEMINI_GENERAL_IMAGE_MODEL=gemini-2.5-flash-image

# 4.3 垂直试衣层
#
# 可选：free | paid | auto
# - free: 走免费/现有通用链路，也要正常产出效果图
# - paid: 按 AI_VERTICAL_TRYON_PROVIDERS_PAID 顺序尝试
# - auto: 有付费密钥时走 paid，否则走 free
AI_VERTICAL_TRYON_TIER=free

# 免费链路：百炼同步图编辑 -> 火山多图参考
AI_VERTICAL_TRYON_PROVIDERS_FREE=bailian,volcengine

# 付费链路建议顺序：FASHN -> 百炼 -> 火山
AI_VERTICAL_TRYON_PROVIDERS_PAID=fashn,bailian,volcengine

# 兼容旧配置名：AI_TRYON_TIER / AI_TRYON_PROVIDERS_FREE / AI_TRYON_PROVIDERS_PAID
# 如新旧同时存在，代码会优先读取 AI_VERTICAL_TRYON_*。

# 百炼：优先走同步通用图编辑模型，稳定性和速度都更适合当前试衣链路
# 专用试衣：aitryon / aitryon-plus
# 通用编辑：qwen-image-2.0 / wan2.7-image / qwen-image-2.0-pro
# BAILIAN_VERTICAL_TRYON_MODEL=qwen-image-2.0
# BAILIAN_VERTICAL_TRYON_API_URL=https://dashscope.aliyuncs.com/api/v1/services/aigc/image2image/image-synthesis
# BAILIAN_VERTICAL_TRYON_TASKS_BASE_URL=https://dashscope.aliyuncs.com/api/v1/tasks
# BAILIAN_VERTICAL_TRYON_RESOLUTION=-1
# BAILIAN_VERTICAL_TRYON_RESTORE_FACE=true
# BAILIAN_VERTICAL_TRYON_TIMEOUT_MS=60000
# BAILIAN_VERTICAL_TRYON_POLL_INTERVAL_MS=3000
# BAILIAN_VERTICAL_GENERAL_IMAGE_SIZE=1024*1536

# FASHN（付费，推荐首选）
# FASHN_API_KEY=your-fashn-api-key
# FASHN_MODEL_NAME=tryon-v1.6
# FASHN_MODE=balanced
# FASHN_TIMEOUT_MS=45000
# FASHN_POLL_INTERVAL_MS=1500

# Vertex Virtual Try-On（付费/备用）
# 说明：当前接入使用 Bearer Token 方式，后续可再升级成服务账号自动鉴权
# GOOGLE_CLOUD_PROJECT=your-gcp-project-id
# GOOGLE_CLOUD_LOCATION=us-central1
# VERTEX_AI_ACCESS_TOKEN=your-short-lived-access-token
# VERTEX_VTO_MODEL=virtual-try-on-preview-08-04
# VERTEX_VTO_BASE_STEPS=32
# VERTEX_VTO_SAFETY_SETTING=block_medium_and_above

# ------------------------------------------------------------
# 五、本地开发说明
# ------------------------------------------------------------
#
# 1. 初始化数据库：
#    在 Supabase SQL Editor 执行 `supabase/init.sql`
#
# 2. 启动开发服务：
#    pnpm dev
#
# 3. 本地默认访问地址：
#    http://localhost:3000
#
# 4. 如果刚修改过 .env.local：
#    需要重启 `pnpm dev` 才会生效
#
# ============================================================
